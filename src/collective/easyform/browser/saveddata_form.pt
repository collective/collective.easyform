<html xmlns="http://www.w3.org/1999/xhtml"
      xmlns:i18n="http://xml.zope.org/namespaces/i18n"
      xmlns:metal="http://xml.zope.org/namespaces/metal"
      xmlns:tal="http://xml.zope.org/namespaces/tal"
      tal:omit-tag=""
      i18n:domain="collective.easyform"
>

  <h1 i18n:translate="">Saved Data</h1>

  <p class="lead"
     tal:content="python: view.description()"
  ></p>

  <p i18n:translate="saveddata_form_description">The saved data of
    <strong tal:content="view/form_title"
            i18n:name="formname"
    >form name</strong>
    stored in the adapter
    <strong tal:content="view/name"
            i18n:name="adapter"
    ></strong></p>

  <div class="portalMessage"
       role="status"
       tal:condition="view/status"
       tal:content="view/status"
  >
  </div>

  <tal:domain i18n:domain="plone.z3cform">

    <div class="crud-form"
         tal:repeat="form view/subforms"
         tal:content="structure form/render"
    >
    </div>

    <metal:form use-macro="context/@@ploneform-macros/titlelessform">
      <metal:top-slot fill-slot="actions">
        <div class="formControls"
             tal:condition="view/actions/values|nothing"
        >
          <div tal:condition="python:view.is_csv"
               tal:attributes="
                 class python:'field error' if view.delimiter_missing else 'field';
               "
          >
            <label for="csv_delimiter"
                   i18n:domain="collective.easyform"
                   i18n:translate=""
            >CSV delimiter</label>
            <div class="error"
                 tal:condition="view/delimiter_missing"
                 i18n:domain="collective.easyform"
                 i18n:translate=""
            >CSV delimiter is required.</div>
            <input id="csv_delimiter"
                   maxlength="1"
                   name="csv_delimiter"
                   size="1"
                   style="width: 3ch; padding-left: 1ch; padding-right: 1ch"
                   type="text"
                   value=";"
                   tal:attributes="
                     value python:view.csv_delimiter;
                   "
            />
          </div>
          <tal:block repeat="action view/actions/values">
            <input type="submit"
                   tal:replace="structure action/render"
            />
          </tal:block>
        </div>
      </metal:top-slot>
    </metal:form>
  </tal:domain>
</html>
